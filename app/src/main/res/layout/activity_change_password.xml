<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/surface_soft" android:orientation="vertical">
    <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/white" android:title="@string/change_password" app:navigationIcon="?attr/homeAsUpIndicator" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView style="@style/TextAppearance.Material3.HeadlineSmall" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Secure your account" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:layout_marginBottom="12dp" android:text="@string/change_password_hint" android:textColor="@color/text_secondary" />
        <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutCurrent" style="@style/AppInput" android:hint="@string/current_password" app:endIconMode="password_toggle"><com.google.android.material.textfield.TextInputEditText android:id="@+id/inputCurrent" style="@style/AppInputEdit" android:inputType="textPassword" /></com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutNew" style="@style/AppInput" android:hint="@string/new_password" app:endIconMode="password_toggle"><com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNew" style="@style/AppInputEdit" android:inputType="textPassword" /></com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutConfirm" style="@style/AppInput" android:hint="@string/confirm_password" app:endIconMode="password_toggle"><com.google.android.material.textfield.TextInputEditText android:id="@+id/inputConfirm" style="@style/AppInputEdit" android:inputType="textPassword" /></com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.button.MaterialButton android:id="@+id/buttonChange" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="20dp" android:text="@string/change_password" app:cornerRadius="16dp" />
        <ProgressBar android:id="@+id/progressBar" android:layout_width="32dp" android:layout_height="32dp" android:layout_gravity="center_horizontal" android:layout_marginTop="12dp" android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
